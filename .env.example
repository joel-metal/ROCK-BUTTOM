# ============================================================================
# ROCK-BUTTOM — root environment overview
# ============================================================================
# Each app has its own detailed template; copy those for real configuration:
#   - apps/web/.env.example       -> apps/web/.env.local
#   - apps/backend/.env.example   -> apps/backend/.env
#
# This root file documents the shared Stellar/Soroban values used by both.

# ── Stellar / Soroban network ───────────────────────────────────────────────
# Testnet (default) or mainnet endpoints.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Deployed contract IDs (fill after deploy) ───────────────────────────────
# Crowdfunding (Fund-My-Cause side)
CROWDFUND_CONTRACT_ID=
REGISTRY_CONTRACT_ID=
# Education / funding-for-education (Brain-Storm side)
SCHOLARSHIP_FUND_CONTRACT_ID=
GRANTS_CONTRACT_ID=
TOKEN_CONTRACT_ID=
CERTIFICATE_CONTRACT_ID=

# ── Backend secrets (see apps/backend/.env.example for the full list) ────────
# DATABASE_URL=postgres://user:password@localhost:5432/rockbuttom
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=
