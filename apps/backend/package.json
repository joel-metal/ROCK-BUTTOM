{
  "name": "@rock-buttom/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "export:openapi": "EXPORT_OPENAPI=true node dist/main --export-openapi",
    "start:prod": "node dist/main",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "jest",
    "test:integration": "jest --config jest-integration.config.js --runInBand",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand",
    "test:pact": "jest --testPathPattern=pact",
    "seed:basic": "ts-node -r tsconfig-paths/register src/test/seeds/basic.seed.ts",
    "seed:performance": "ts-node -r tsconfig-paths/register src/test/seeds/performance.seed.ts",
    "seed:cleanup": "ts-node -r tsconfig-paths/register src/test/seeds/cleanup.seed.ts",
    "migration:run": "ts-node -r tsconfig-paths/register src/migrations/migration-runner.ts",
    "migration:rollback": "ts-node -r tsconfig-paths/register src/migrations/migration-rollback.ts",
    "migration:validate": "ts-node -r tsconfig-paths/register src/migrations/migration-validator.ts",
    "migration:create": "typeorm migration:create",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/data-source.ts"
  },
  "dependencies": {
    "@rock-buttom/types": "*",
    "@aws-sdk/client-comprehend": "^3.758.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/elasticsearch": "^10.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^11.1.19",
    "@sentry/nestjs": "^8.0.0",
    "@sentry/profiling-node": "^8.55.1",
    "@stellar/stellar-sdk": "^12.0.0",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "adm-zip": "^0.5.16",
    "bcrypt": "^5.1.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-store": "^3.0.1",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "nest-winston": "^1.9.0",
    "nodemailer": "^6.9.0",
    "otplib": "^13.4.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-headerapikey": "^1.2.2",
    "passport-jwt": "^4.0.0",
    "pg": "^8.11.0",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.0",
    "winston": "^3.11.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@pact-foundation/pact": "^16.3.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^29.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@faker-js/faker": "^8.4.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "testcontainers": "^10.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
