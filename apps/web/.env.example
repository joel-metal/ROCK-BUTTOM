# ============================================
# Fund-My-Cause Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values
# See docs/environment-config.md for detailed documentation

# ============================================
# Contract Addresses
# ============================================
# Crowdfund contract address
NEXT_PUBLIC_CROWDFUND_CONTRACT_ID=

# Registry contract address
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=

# Legacy support (deprecated, use CROWDFUND_CONTRACT_ID)
NEXT_PUBLIC_CONTRACT_ID=

# ============================================
# Network Configuration
# ============================================
# Soroban RPC endpoint
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase
# Testnet: Test SDF Network ; September 2015
# Mainnet: Public Global Stellar Network ; September 2015
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Horizon REST API endpoint
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ============================================
# Optional: IPFS Configuration
# ============================================
# Pinata IPFS — get keys at https://app.pinata.cloud/keys
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_KEY=

# ============================================
# Optional: Application Features
# ============================================
# Comma-separated list of featured campaign contract IDs
# If unset, the landing page falls back to hardcoded demo campaigns
NEXT_PUBLIC_FEATURED_CAMPAIGNS=

# Enable/disable analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Analytics tracking ID (if enabled)
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================
# Environment
# ============================================
# development | production
NODE_ENV=development
