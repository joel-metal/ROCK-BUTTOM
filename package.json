{
  "name": "rock-buttom",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Stellar/Soroban platform — education credentials + crowdfunding",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=apps/web --if-present",
    "contracts:build": "cargo build --release --target wasm32-unknown-unknown",
    "contracts:test": "cargo test --workspace",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
